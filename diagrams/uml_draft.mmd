classDiagram
    class Task {
        +str description
        +str time
        +str frequency
        +bool completed
        +mark_complete()
    }

    class Pet {
        +str name
        +str species
        +int age
        +list~Task~ tasks
        +add_task(task)
    }

    class Owner {
        +str name
        +list~Pet~ pets
        +add_pet(pet)
    }

    class Scheduler {
        +Owner owner
        +get_all_tasks()
        +sort_by_time()
        +filter_tasks(status)
        +detect_conflicts()
    }

    Owner "1" --> "*" Pet : has
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "1" Owner : manages